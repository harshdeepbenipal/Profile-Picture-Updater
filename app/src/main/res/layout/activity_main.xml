<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@color/white"
    android:layout_gravity="center"
    tools:context=".MainActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:layout_constraintTop_toTopOf="parent"

        android:background="@color/blue"
        app:title="PROFILE PICKER"
        />

    <!-- ImageView be invisible until an action is done?-->

    <!-- Button for 'using picture' be invisible until an action is done?-->

    <Button
        android:id="@+id/PhotoButton"
        android:layout_width="300dp"
        android:layout_height="70dp"

        android:layout_marginTop="48dp"
        android:text="Take Photo"

        android:textSize="20sp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ImageDisplay" />

    <Button
        android:id="@+id/FileButton"
        android:layout_width="300dp"
        android:layout_height="70dp"

        android:layout_marginTop="32dp"
        android:text="Select from Gallery"
        android:textSize="20sp"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/PhotoButton" />

    <ImageView
        android:id="@+id/ImageDisplay"
        android:layout_width="236dp"
        android:layout_height="250dp"
        android:layout_marginTop="64dp"
        android:adjustViewBounds="true"

        android:scaleType="centerCrop"
        android:src="@drawable/default_pfp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar" />


