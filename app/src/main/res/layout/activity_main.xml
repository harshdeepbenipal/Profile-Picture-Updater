<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@color/white"
    android:layout_gravity="center"
    tools:context=".MainActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:layout_constraintTop_toTopOf="parent"

        android:background="@color/blue"
        app:title="PROFILE PICKER"
        />

    <Button
        android:id="@+id/PhotoButton"
        android:layout_width="300dp"
        android:layout_height="70dp"

        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="30dp"

        android:text="Take Photo"
        android:textSize="20sp"
        />

    <Button
        android:id="@+id/FileButton"
        android:layout_width="300dp"
        android:layout_height="70dp"

        app:layout_constraintTop_toBottomOf="@id/PhotoButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="30dp"

        android:text="Select from Gallery"
        android:textSize="20sp"
        />

    <!-- ImageView be invisible until an action is done?-->
    <ImageView
        android:id="@+id/ImageDisplay"
        android:layout_width="300dp"
        android:layout_height="300dp"

        app:layout_constraintTop_toBottomOf="@id/FileButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="50dp"

        android:visibility="invisible"
        />

    <!-- Button for 'using picture' be invisible until an action is done?-->
    <Button
        android:id="@+id/UseButton"
        android:layout_width="150dp"
        android:layout_height="50dp"

        app:layout_constraintTop_toBottomOf="@id/ImageDisplay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="10dp"

        android:text = "Use Picture"
        android:textSize="18dp"
        android:backgroundTint="@color/green"

        android:visibility="invisible"
        />


